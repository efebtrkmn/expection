// ============================================================
// Expection — Prisma Schema
// Multi-Tenant SaaS Muhasebe Platformu
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum TenantPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  SuperAdmin
  Accountant
  Auditor
  ClientUser
}

enum CustomerSupplierType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum InvoiceType {
  SALES
  PURCHASE
  RETURN_SALES
  RETURN_PURCHASE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  IYZICO
  PAYTR
  CHECK
  OTHER
}

enum AuditAction {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  CREATE
  UPDATE
  DELETE
  VIEW
  EXPORT
  TOKEN_REFRESH
}

// ============================================================
// TENANTS — Kiracı Ana Kaydı
// ============================================================

model Tenant {
  id                  String      @id @default(uuid()) @db.Uuid
  name                String      @db.VarChar(255)
  domain              String      @unique @db.VarChar(255)
  plan                TenantPlan  @default(STARTER)
  status              TenantStatus @default(TRIAL)
  subscriptionEndsAt  DateTime?   @map("subscription_ends_at")
  logoUrl             String?     @map("logo_url")
  taxNumber           String?     @map("tax_number") @db.VarChar(11)
  address             String?     @db.Text
  phone               String?     @db.VarChar(20)
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  // İlişkiler
  users               User[]
  customersSuppliers  CustomerSupplier[]
  invoices            Invoice[]
  transactions        Transaction[]
  accountLedgers      AccountLedger[]
  auditLogs           AuditLog[]
  refreshTokens       RefreshToken[]

  @@map("tenants")
}

// ============================================================
// USERS — Kullanıcılar
// ============================================================

model User {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  email          String    @db.VarChar(255)
  passwordHash   String    @map("password_hash") @db.Text
  role           UserRole  @default(Accountant)
  fullName       String    @map("full_name") @db.VarChar(255)
  isActive       Boolean   @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  // Müşteri kullanıcıları için bağlı olduğu cari hesap
  customerId     String?   @map("customer_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // İlişkiler
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer       CustomerSupplier? @relation(fields: [customerId], references: [id])
  auditLogs      AuditLog[]
  refreshTokens  RefreshToken[]
  createdInvoices Invoice[] @relation("InvoiceCreatedBy")

  // Aynı tenant içinde email unique olmalı
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@map("users")
}

// ============================================================
// CUSTOMERS_SUPPLIERS — Cari Hesaplar
// ============================================================

model CustomerSupplier {
  id          String               @id @default(uuid()) @db.Uuid
  tenantId    String               @map("tenant_id") @db.Uuid
  type        CustomerSupplierType @default(CUSTOMER)
  name        String               @db.VarChar(255)
  taxNumber   String?              @map("tax_number") @db.VarChar(11)
  taxOffice   String?              @map("tax_office") @db.VarChar(255)
  address     String?              @db.Text
  city        String?              @db.VarChar(100)
  country     String?              @default("TR") @db.VarChar(2)
  phone       String?              @db.VarChar(20)
  email       String?              @db.VarChar(255)
  balance     Decimal              @default(0) @db.Decimal(18, 2)
  isActive    Boolean              @default(true) @map("is_active")
  notes       String?              @db.Text
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  // İlişkiler
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices    Invoice[]
  users       User[]

  // Aynı tenant içinde vergi numarası unique
  @@unique([tenantId, taxNumber])
  @@index([tenantId])
  @@index([tenantId, type])
  @@map("customers_suppliers")
}

// ============================================================
// INVOICES — Faturalar
// ============================================================

model Invoice {
  id                  String        @id @default(uuid()) @db.Uuid
  tenantId            String        @map("tenant_id") @db.Uuid
  customerSupplierId  String        @map("customer_supplier_id") @db.Uuid
  invoiceNumber       String        @map("invoice_number") @db.VarChar(50)
  type                InvoiceType
  status              InvoiceStatus @default(DRAFT)
  issueDate           DateTime      @map("issue_date") @db.Date
  dueDate             DateTime?     @map("due_date") @db.Date
  subtotal            Decimal       @db.Decimal(18, 2)
  discountAmount      Decimal       @default(0) @map("discount_amount") @db.Decimal(18, 2)
  taxAmount           Decimal       @db.Decimal(18, 2) @map("tax_amount")
  totalAmount         Decimal       @map("total_amount") @db.Decimal(18, 2)
  currency            String        @default("TRY") @db.VarChar(3)
  // e-Belge entegrasyonu
  eInvoiceUuid        String?       @map("e_invoice_uuid") @db.Uuid
  eArchiveUrl         String?       @map("e_archive_url") @db.Text
  eInvoiceStatus      String?       @map("e_invoice_status") @db.VarChar(50)
  // İçerik
  notes               String?       @db.Text
  lineItems           Json?         @map("line_items") @db.JsonB
  createdById         String        @map("created_by") @db.Uuid
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // İlişkiler
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerSupplier    CustomerSupplier @relation(fields: [customerSupplierId], references: [id])
  createdBy           User             @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  transactions        Transaction[]

  // Aynı tenant içinde fatura numarası unique
  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, issueDate])
  @@map("invoices")
}

// ============================================================
// TRANSACTIONS — Kasa / Banka Hareketleri
// ============================================================

model Transaction {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  invoiceId       String?         @map("invoice_id") @db.Uuid
  type            TransactionType
  amount          Decimal         @db.Decimal(18, 2)
  currency        String          @default("TRY") @db.VarChar(3)
  description     String?         @db.Text
  transactionDate DateTime        @map("transaction_date") @db.Date
  paymentMethod   PaymentMethod   @map("payment_method")
  referenceNumber String?         @map("reference_number") @db.VarChar(100)
  // Ödeme geçidi bilgileri
  gatewayRef      String?         @map("gateway_ref") @db.VarChar(255)
  gatewayStatus   String?         @map("gateway_status") @db.VarChar(50)
  createdById     String          @map("created_by") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at")

  // İlişkiler
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([tenantId, transactionDate])
  @@index([tenantId, invoiceId])
  @@map("transactions")
}

// ============================================================
// ACCOUNT_LEDGERS — Muhasebe Defteri (Yevmiye)
// ============================================================

model AccountLedger {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  accountCode   String   @map("account_code") @db.VarChar(20)
  accountName   String   @map("account_name") @db.VarChar(255)
  debit         Decimal  @default(0) @db.Decimal(18, 2)
  credit        Decimal  @default(0) @db.Decimal(18, 2)
  balance       Decimal  @default(0) @db.Decimal(18, 2)
  entryDate     DateTime @map("entry_date") @db.Date
  description   String?  @db.Text
  referenceId   String?  @map("reference_id") @db.Uuid
  referenceType String?  @map("reference_type") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at")

  // İlişkiler
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, accountCode])
  @@index([tenantId, entryDate])
  @@map("account_ledgers")
}

// ============================================================
// AUDIT_LOGS — KVKK Loglama (Immutable)
// INSERT ONLY — UPDATE/DELETE YASAK (DB seviyesinde kısıtlanır)
// ============================================================

model AuditLog {
  id          BigInt      @id @default(autoincrement())
  tenantId    String?     @map("tenant_id") @db.Uuid
  userId      String?     @map("user_id") @db.Uuid
  action      AuditAction
  entityType  String?     @map("entity_type") @db.VarChar(100)
  entityId    String?     @map("entity_id") @db.VarChar(255)
  ipAddress   String?     @map("ip_address") @db.VarChar(45)
  userAgent   String?     @map("user_agent") @db.Text
  oldValues   Json?       @map("old_values") @db.JsonB
  newValues   Json?       @map("new_values") @db.JsonB
  metadata    Json?       @db.JsonB
  createdAt   DateTime    @default(now()) @map("created_at")

  // İlişkiler
  tenant      Tenant?     @relation(fields: [tenantId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ============================================================
// REFRESH_TOKENS — JWT Refresh Token Yönetimi
// ============================================================

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  tokenHash   String    @map("token_hash") @db.VarChar(255)
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  userAgent   String?   @map("user_agent") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  // İlişkiler
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}
