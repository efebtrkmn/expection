# ============================================================
# Expection Backend — Environment Variables
# Bu dosyayı kopyalayıp .env olarak düzenleyin
# ============================================================

# ---------------------
# Uygulama
# ---------------------
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ---------------------
# Veritabanı (PostgreSQL)
# ---------------------
DATABASE_URL="postgresql://expection_app:STRONG_PASSWORD@localhost:5432/expection_db?schema=public"
# Migration'lar için superadmin bağlantısı (RLS bypass yetkisi olan kullanıcı)
DATABASE_MIGRATION_URL="postgresql://expection_admin:ADMIN_PASSWORD@localhost:5432/expection_db?schema=public"

# ---------------------
# JWT
# ---------------------
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------
# CORS
# ---------------------
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ---------------------
# Rate Limiting
# ---------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100
AUTH_THROTTLE_LIMIT=5

# ---------------------
# Loglama
# ---------------------
LOG_LEVEL=debug
